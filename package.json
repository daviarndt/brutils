{
  "name": "@danielarndt0/brutils-cli",
  "version": "0.4.0",
  "description": "Core Brazilian developer utilities as a modular CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "brutils": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "cli": "tsx src/cli.ts",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "cpf:generate": "tsx scripts/cpf/generate.ts",
    "cpf:validate": "tsx scripts/cpf/validate.ts",
    "cpf:format": "tsx scripts/cpf/format.ts",
    "cpf:strip": "tsx scripts/cpf/strip.ts",
    "cpf:mask": "tsx scripts/cpf/mask.ts",
    "cnpj:generate": "tsx scripts/cnpj/generate.ts",
    "cnpj:validate": "tsx scripts/cnpj/validate.ts",
    "cnpj:format": "tsx scripts/cnpj/format.ts",
    "cnpj:strip": "tsx scripts/cnpj/strip.ts",
    "cnpj:mask": "tsx scripts/cnpj/mask.ts",
    "cep:generate": "tsx scripts/cep/generate.ts",
    "cep:validate": "tsx scripts/cep/validate.ts",
    "cep:format": "tsx scripts/cep/format.ts",
    "cep:strip": "tsx scripts/cep/strip.ts",
    "cep:mask": "tsx scripts/cep/mask.ts",
    "credit-card:generate": "tsx scripts/credit-card/generate.ts",
    "credit-card:validate": "tsx scripts/credit-card/validate.ts",
    "credit-card:detect": "tsx scripts/credit-card/detect.ts",
    "random-number:generate": "tsx scripts/random-number/generate.ts",
    "random-number:int": "tsx scripts/random-number/int.ts",
    "random-number:float": "tsx scripts/random-number/float.ts",
    "random-number:pick": "tsx scripts/random-number/pick.ts",
    "random-number:shuffle": "tsx scripts/random-number/shuffle.ts",
    "random-number:dice": "tsx scripts/random-number/dice.ts",
    "random-number:coin": "tsx scripts/random-number/coin.ts",
    "number-picker:run": "tsx scripts/number-picker/run.ts",
    "zip:run": "tsx scripts/zip/run.ts",
    "zip:create": "tsx scripts/zip/create.ts",
    "zip:list": "tsx scripts/zip/list.ts",
    "zip:test": "tsx scripts/zip/test.ts",
    "unzip:run": "tsx scripts/unzip/run.ts",
    "unzip:extract": "tsx scripts/unzip/extract.ts",
    "unzip:list": "tsx scripts/unzip/list.ts",
    "unzip:test": "tsx scripts/unzip/test.ts",
    "str:slug": "tsx src/cli.ts str slug",
    "str:case": "tsx src/cli.ts str case",
    "str:trim": "tsx src/cli.ts str trim",
    "str:truncate": "tsx src/cli.ts str truncate",
    "str:replace": "tsx src/cli.ts str replace",
    "str:normalize": "tsx src/cli.ts str normalize",
    "str:remove-accents": "tsx src/cli.ts str remove-accents",
    "str:pad": "tsx src/cli.ts str pad",
    "str:extract": "tsx src/cli.ts str extract",
    "str:base64": "tsx src/cli.ts str base64",
    "str:urlencode": "tsx src/cli.ts str urlencode",
    "str:html": "tsx src/cli.ts str html",
    "json:format": "tsx src/cli.ts json format",
    "json:minify": "tsx src/cli.ts json minify",
    "json:validate": "tsx src/cli.ts json validate",
    "json:get": "tsx src/cli.ts json get",
    "json:set": "tsx src/cli.ts json set",
    "json:delete": "tsx src/cli.ts json delete",
    "json:diff": "tsx src/cli.ts json diff",
    "json:merge": "tsx src/cli.ts json merge",
    "json:to-yaml": "tsx src/cli.ts json to-yaml"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "commander": "^12.1.0",
    "extract-zip": "^2.0.1",
    "fast-glob": "^3.3.3",
    "minimatch": "^3.1.5",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/archiver": "^7.0.0",
    "@types/node": "^24.0.0",
    "@types/yauzl": "^2.10.3",
    "eslint": "^9.20.1",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  }
}
